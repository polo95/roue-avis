rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /lots/{lotId} {
      allow read, write: if true;
    }
    match /empreintes/{empreinteId} {
      allow read, write: if true;
    }
    match /participations/{participationId} {
      allow read, write: if true;
    }
  }
}
